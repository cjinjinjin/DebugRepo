#DECLARE py_expr string = "Segmentator()";
#DECLARE py_prologue string = @"#!/usr/bin/env python 
import json
from collections import OrderedDict
import sys
 
 
class Segmentator:
 
    def Process(self, inputRow, outputRow):
        outputRow['AdExtensionItemId'] = inputRow['AdExtensionItemId']
        outputRow['AdExtensionId'] = inputRow['AdExtensionId']
        outputRow['AssetId'] = inputRow['AssetId']
        outputRow['MediaURL'] = inputRow['MediaURL']
        outputRow['DestintationUrl'] = inputRow['DestintationUrl']
        outputRow['OriginalMediaHeight'] = inputRow['OriginalMediaHeight']
        outputRow['OriginalMediaWidth'] = inputRow['OriginalMediaWidth']
        outputRow['AltText'] = inputRow['AltText']
        outputRow['AssetId2'] = inputRow['AssetId2']
        outputRow['AssetId3'] = inputRow['AssetId3']
        outputRow['AssetId4'] = inputRow['AssetId4']
        outputRow['AssetId5'] = inputRow['AssetId5']
    
        json_str = inputRow['AssetId5']
        json_list = json.loads(json_str)

        ids = [item['id'] for item in json_list]
        for i in range(8):
            column_name = 'AssetId' + str(6+i)
            if i < len(ids):
                outputRow[column_name] = str(ids[i])
            else:
                outputRow[column_name] = ''
            
        return outputRow
 
";

HotAds_ImageExtension =
    SELECT AdExtensionItemId.ToString() AS AdExtensionItemId,
            AdExtensionId.ToString() AS AdExtensionId,
            AssetId,
            MediaURL,
            DestintationUrl,
            OriginalMediaHeight,OriginalMediaWidth,AltText, AssetId2, AssetId3, AssetId4, AssetId5
    FROM AccountImageExtension
    UNION ALL
    SELECT AdExtensionItemId.ToString() AS AdExtensionItemId,
            AdExtensionId.ToString() AS AdExtensionId,
            AssetId,
            MediaURL,
            DestintationUrl,
            OriginalMediaHeight,OriginalMediaWidth,AltText, AssetId2, AssetId3, AssetId4, AssetId5
    FROM CampaignImageExtension UNION ALL
    SELECT AdExtensionItemId.ToString() AS AdExtensionItemId,
            AdExtensionId.ToString() AS AdExtensionId,
            AssetId,
            MediaURL,
            DestintationUrl,
            OriginalMediaHeight,OriginalMediaWidth,AltText, AssetId2, AssetId3, AssetId4, AssetId5
    FROM OrderImageExtension;

// extract AssetId6 ~ AssetId13
HotAds_ImageExtension_WithAssetId5 =
    SELECT *
    FROM HotAds_ImageExtension
    WHERE !String.IsNullOrEmpty(AssetId5);

HotAds_ImageExtension_WithoutAssetId5 = 
    SELECT * FROM HotAds_ImageExtension
    WHERE String.IsNullOrEmpty(AssetId5);

HotAds_ImageExtension_WithAssetId5 = PROCESS HotAds_ImageExtension_WithAssetId5
         PRODUCE AdExtensionItemId:string,
            AdExtensionId:string,
            AssetId:string,
            MediaURL:string,
            DestintationUrl:string,
            OriginalMediaHeight:string,OriginalMediaWidth:string,AltText:string, AssetId2:string, AssetId3:string, AssetId4:string, AssetId5:string,
            AssetId6: string, AssetId7: string, AssetId8: string, AssetId9: string, AssetId10: string, AssetId11: string, AssetId12: string, AssetId13: string
         USING Processors.Python(prologue: @py_prologue, expression: @py_expr);
 
HotAds_ImageExtension_WithAllAssetIds = SELECT AdExtensionItemId, AdExtensionId, MediaURL, DestintationUrl, OriginalMediaHeight, OriginalMediaWidth, AltText, AssetId AS AssetId1, AssetId2, AssetId3, AssetId4 AS AssetId4, "" AS AssetId6, "" AS AssetId7, "" AS AssetId8, "" AS AssetId9, "" AS AssetId10, "" AS AssetId11, "" AS AssetId12, "" AS AssetId13 FROM HotAds_ImageExtension_WithoutAssetId5
      UNION ALL
      SELECT AdExtensionItemId, AdExtensionId, MediaURL, DestintationUrl, OriginalMediaHeight, OriginalMediaWidth, AltText, AssetId AS AssetId1,  AssetId2, AssetId3, AssetId4, AssetId6, AssetId7, AssetId8, AssetId9, AssetId10, AssetId11, AssetId12, AssetId13 FROM HotAds_ImageExtension_WithAssetId5;

// Flatten AssetIds
HotAds_ImageExtension_FlatAssetIds = SELECT AdExtensionItemId,
             AdExtensionId,
             MediaURL,
             DestintationUrl,
             OriginalMediaHeight,
             OriginalMediaWidth,
             AltText,
             AssetIds AS MergeAssetId
      FROM HotAds_ImageExtension_WithAllAssetIds
           CROSS APPLY new List<string>{AssetId1, AssetId2, AssetId3, AssetId4, AssetId6, AssetId7, AssetId8, AssetId9, AssetId10, AssetId11, AssetId12, AssetId13} AS AssetIds;
HotAds_ImageExtension_FlatAssetIds = SELECT * FROM HotAds_ImageExtension_FlatAssetIds WHERE !String.IsNullOrEmpty(MergeAssetId);

// New: 2025-11-10: filter display ads
AccountAssetPair = 
    SELECT  
        AccountID AS AccountId, AdId, AssetId, AdAssetAssociationTypeId AS AssetAssociationTypeId
        FROM 
        ( 
            VIEW @C2CMasterViewPath 
            PARAMS 
            ( 
                ViewName = "AdAsset_Raw", 
                ViewType = 1, 
                DataMode = "PROD",
                ViewMode = "PROD",
                IncludeDeletedRecordsForType1Data = true 
            ) 
        ) WHERE IsSoftDeleted != true AND AdId != null AND AssetId != null
        AND AdAssetAssociationTypeId == 80;

HotAds_ImageExtension_FlatAssetIds =
    SELECT *
    FROM HotAds_ImageExtension_FlatAssetIds
    LEFT ANTISEMIJOIN
        AccountAssetPair
        ON HotAds_ImageExtension_FlatAssetIds.MergeAssetId == AccountAssetPair.AssetId;

// activate AssetId filtered by raw data
AssetImages = SSTREAM SPARSE STREAMSET "/shares/bingAds.BI.OI/AdsOI/ObjectStoreDump/Images" PATTERN @"Assets_2025_11_05" + @"_%n.ss" RANGE __serialnum=["1", "5"]; 
RawDataImageExtension = SELECT DISTINCT AssetId.ToString() AS AssetId,Base64Data FROM AssetImages;

HotAds_ImageExtension_FlatAssetIds =
    SELECT *
    FROM HotAds_ImageExtension_FlatAssetIds
    LEFT SEMIJOIN
        RawDataImageExtension
        ON HotAds_ImageExtension_FlatAssetIds.MergeAssetId == RawDataImageExtension.AssetId;

HotAds_ImageExtension_FirstImage = SELECT AdExtensionItemId,
             AdExtensionId,
             MediaURL,
             DestintationUrl,
             OriginalMediaHeight,
             OriginalMediaWidth,
             AltText,
             FIRST(MergeAssetId) AS AssetId FROM HotAds_ImageExtension_FlatAssetIds GROUP BY AdExtensionItemId, AdExtensionId,  MediaURL, DestintationUrl, OriginalMediaHeight, OriginalMediaWidth, AltText;


OUTPUT TO SSTREAM @OutputSSPath WITH STREAMEXPIRY "90";
