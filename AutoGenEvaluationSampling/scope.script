// Constants
#DECLARE ViewWindow int = 0;

#DECLARE GeneratedStartDate DateTime = @RunDate.AddDays(1 - @RunDate.Day);
#DECLARE GeneratedEndDate DateTime = @RunDate;
#DECLARE GeneratedDuration int = 1 + (@GeneratedEndDate - @GeneratedStartDate).Days;

#DECLARE ViewStartDate DateTime = @GeneratedStartDate;
#DECLARE ViewDuration int = @GeneratedDuration + @ViewWindow;
#DECLARE ViewEndDate DateTime = @ViewStartDate.AddDays(@ViewDuration - 1);
#DECLARE ViewStartDateStr string = @ViewStartDate.ToString("yyyy-MM-dd");
#DECLARE ViewEndDateStr string = @ViewEndDate.ToString("yyyy-MM-dd");
#DECLARE CurrentDataStrforImage string = @RunDate.ToString("yyyy_MM_dd");


// Input Streams
#DECLARE AccSegRoot string = "/shares/bingads.algo.prod.adinsights/data/shared_data/DemandResources/AccountSegment/";
#DECLARE AccSegPath string = string.Format("{0}/{1:yyyy/MM}/AccountSegment_{1:yyyy-MM-dd}.ss", @AccSegRoot, @GeneratedEndDate);
#DECLARE C2CMasterViewPath string = "/shares/adCenter.BICore.upload/prod/C2C/Views/MasterView/C2CMasterView.view"; 

#DECLARE UcmTacticInfoFile string = "/shares/bingads.algo.prod.adinsights/data/prod/pipelines/Optimization/UCM/Data/UcmTacticInfo.csv";
#DECLARE CDLFolder string = "/shares/bingads.algo.prod.adinsights/data/shared_data/AdvertiserEngagement/Metallica/prod/CommonDataFeed/";
#DECLARE AccountVertical string = @CDLFolder + "/Modules/AccountVertical.view"; // Account vertical

AssetImages =
    SSTREAM SPARSE STREAMSET "/shares/bingAds.BI.OI/AdsOI/ObjectStoreDump/Images"
                   PATTERN @"Assets_"+@CurrentDataStrforImage + @"_%n.ss"
                   RANGE __serialnum = ["1", "5"];

#DECLARE UnifiedLayerDemandView string = @"/shares/bingAds.BI.OI/AdsOI/DemandMetrics/Views/UnifiedLayerDemand.view"; 

// Output Streams
#DECLARE AccountInfoFile string = string.Format("{0}/{1:yyyy/MM}/AccountInfo_{1:yyyy-MM-dd}.ss", @OutputFolder, @RunDate);
#DECLARE SampledAccountsFile string = string.Format("{0}/{1:yyyy/MM}/SampledAccounts_{1:yyyy-MM-dd}.ss", @OutputFolder, @RunDate);
#DECLARE AllAccountsFile string = string.Format("{0}/{1:yyyy/MM}/AllAccounts_{1:yyyy-MM-dd}.ss", @OutputFolder, @RunDate);
#DECLARE AggregatedAccountImagesFile string = string.Format("{0}/{1:yyyy/MM}/AggregatedAccountImagesFile_{1:yyyy-MM-dd}.ss", @OutputFolder, @RunDate);
#DECLARE RatioDistributionFile string = string.Format("{0}/{1:yyyy/MM}/RatioDistribution_{1:yyyy-MM-dd}.ss", @OutputFolder, @RunDate);
#DECLARE SampledNoAccountsFile string = string.Format("{0}/{1:yyyy/MM}/SampledNoAccounts_{1:yyyy-MM-dd}.ss", @OutputFolder, @RunDate);
#DECLARE StatFile string = string.Format("{0}/{1:yyyy/MM}/Stat_{1:yyyy-MM-dd}.ss", @OutputFolder, @RunDate);
// Account Information
// Customer Mapping
AccountCustomer =
    SELECT AccountId,
           CustomerId
    FROM C2C.Account(DataDate = @GeneratedEndDate);

// IsPerforming
AccountPerf =
    SELECT AccountId,
           (double)SUM(RevenueUSD) AS RevenueUSD,
           (double)SUM(Impressions) AS Impressions,
           (double)SUM(Clicks) AS Clicks
    FROM
    (
        VIEW @UnifiedLayerPerf
        PARAMS
        (
            ViewName = "AccountPerf",
            TimeZoneForUnifiedLayerPerf = "CampaignTimeZone",
            StartDate = @GeneratedStartDate.AddDays(-366),
            EndDate = @GeneratedStartDate.AddDays(-1)
        )
    );

// IsServable
AccountServable = 
    SELECT DISTINCT AccountId, 
                    AdId,
                    AdTypeId,
                    AdTitle,
		            IsServable 
    FROM 
    ( 
        VIEW @UnifiedLayerDemandView 
        PARAMS 
        ( 
            ViewName = "Ads", 
            LogDate = @RunDate 
        ) 
    ) WHERE IsServable == true; 

// Segment
AccountSegment =
    SELECT AccountId,
           Segment.Trim() AS Segment
    FROM (SSTREAM @AccSegPath);

//Get verticals
AccountVertical =
    VIEW @AccountVertical;

AccountInfo =
    SELECT C.AccountId,
           C.CustomerId,
           S.Segment ?? "UnSegmented" AS Segment,
           P.RevenueUSD,
           V.L1 AS Vertical_L1,
           V.L2 AS Vertical_L2,
           V.L3 AS Vertical_L3,
           V.L4 AS Vertical_L4,
           P.RevenueUSD > 0 AS IsPerforming,
           FIRST(Q.AdTypeId) AS AdTypeId
    FROM AccountCustomer AS C
        LEFT OUTER JOIN AccountPerf AS P
            ON C.AccountId == P.AccountId
        LEFT OUTER JOIN AccountSegment AS S
            ON C.AccountId == S.AccountId
        LEFT OUTER JOIN AccountVertical AS V
            ON C.AccountId == V.AccountId
        LEFT OUTER JOIN AccountServable AS Q
            ON C.AccountId == Q.AccountId;

// keep RevenueUSD >0 & exclude sensitive Vertical
ValidAccounts =
    SELECT *, 
           (AdTypeId == 1 ? "TextAd" : AdTypeId == 1024? "ExTA" : AdTypeId == 8192? "RSA" : AdTypeId == 4096? "MMA" : AdTypeId == 256? "AppInstall" : AdTypeId == 5? "ProductListingAd" : "Unknown") AS AdTypeMV 
    FROM AccountInfo
    WHERE RevenueUSD > 0 
          AND Vertical_L1 NOT IN ("Health & Wellness", "Adult & Gambling", "Financial Services & Insurance") 
          AND Vertical_L2 NOT IN ("Drug/Pharma (Retail)");

// only one account per customId
//ValidAccounts = 
//    SELECT *,
//            ROW_NUMBER() OVER (
//               PARTITION BY CustomerId 
//               ORDER BY RandomGenerator.GetRandom()
//               DESC
//           ) AS RevenueRank
//    FROM ValidAccounts 
//    HAVING RevenueRank == 1;

Stat =
    SELECT "#0 after sensitive Vertical condition" AS key,
           Segment,
           COUNT(DISTINCT AccountId) AS SampleAccountIdCount,
           SUM(RevenueUSD) AS TotalRevenue
    FROM ValidAccounts
    ;



AccountAssetPair = 
    SELECT  
        AccountID AS AccountId, AdId, AssetId, AdAssetAssociationTypeId AS AssetAssociationTypeId
        FROM 
        ( 
            VIEW @C2CMasterViewPath 
            PARAMS 
            ( 
                ViewName = "AdAsset_Raw", 
                ViewType = 1, 
                DataMode = "PROD",
                ViewMode = "PROD",
                IncludeDeletedRecordsForType1Data = true 
            ) 
        ) WHERE LifeCycleStatusId == 71 AND IsSoftDeleted != true AND AdId != null AND AssetId != null
        AND AdAssetAssociationTypeId IN (11,12,32,33,34,1,2,3,4,5,6,7,8,9,13,14,31,35);

AccountAssetPair_Pmax = 
    SELECT AccountId,
           AdId,
           //(long) AssetGroupId AS AssetGroupId,
           AssetId,
           AssetAssociationTypeId,
           "Pmax" AS AdType
    FROM
    (
        VIEW @C2CMasterViewPath
        PARAMS
        (
            ViewName = "AssetGroupAssetAssociation_Raw",
            ViewType = 1,
            RequestEndDateUtc = @RunDate,
            RequestEndHourUtc = 23
        )
    )
    WHERE AssetAssociationTypeId IN (32,33,34,1,2,3,4,7,9,13,31,35,63);

AccountAssets =
    SELECT AccountId,
           AssetId,
           AssetAssociationTypeId,
           "" AS AdType
    FROM AccountAssetPair
    UNION
    SELECT AccountId,
           AssetId,
           AssetAssociationTypeId,
           AdType
    FROM AccountAssetPair_Pmax;

AccountAssets =
    SELECT AccountId,
           AssetId,
           AdType,
           IF(AssetAssociationTypeId IN(11, 32), "Headline", IF(AssetAssociationTypeId == 33, "LongHeadline", IF(AssetAssociationTypeId IN(12, 34), "Description", IF(AssetAssociationTypeId == 63, "BusinessName", IF(AssetAssociationTypeId == 1, "LandscapeImage", IF(AssetAssociationTypeId == 2, "SquareImage", IF(AssetAssociationTypeId == 3 OR AssetAssociationTypeId == 4, "Logo", "OtherSizeImage"))))))) AS AssetType
    FROM AccountAssets
    HAVING AssetType != "Logo";

// ImageExtension
AdExtensionAccountView =  
            SELECT AccountId,  
                   AdExtensionId  
            FROM  
            (  
                VIEW @C2CMasterViewPath  
                PARAMS  
                (  
                      ViewName = "AdExtensionAccount_Raw",  
                      ViewType=1,                
                      RequestEndDateUtc= @RunDate,  
                    RequestEndHourUtc = 23          
                )  
            )
    WHERE LifeCycleStatusId != 110;
AdExtensionCampaignView =  
            SELECT AccountID AS AccountId,  
                   AdExtensionId  
            FROM  
            (  
    VIEW @C2CMasterViewPath  
            PARAMS   
            (  
                      ViewName = "AdExtensionCampaign_Raw",  
                      ViewType=1,                
                      RequestEndDateUtc= @RunDate,  
                RequestEndHourUtc = 23 
                )  
            )
    WHERE LifeCycleStatusId != 110;

AdExtensionOrderView =  
            SELECT AccountID AS AccountId,  
                   AdExtensionId  
            FROM  
            (  
                VIEW @C2CMasterViewPath  
                PARAMS  
                (  
                      ViewName = "AdExtensionOrder_Raw",  
                      ViewType=1,                
                      RequestEndDateUtc= @RunDate,  
                    RequestEndHourUtc = 23  
                )  
            )
            WHERE LifeCycleStatusId != 110;
AdExtensionData =
        SELECT AccountId, AdExtensionId.ToString() AS AdExtensionId FROM AdExtensionAccountView
        UNION
        SELECT AccountId, AdExtensionId.ToString() AS AdExtensionId FROM AdExtensionCampaignView
        UNION
        SELECT AccountId, AdExtensionId.ToString() AS AdExtensionId FROM AdExtensionOrderView;

FullExtensionItemAssets = SELECT
                            AdExtensionId,
                            AssetId
                          FROM 
                          (
                              SSTREAM "/local/user/jinjinchen/AdDemandMeasurement/2025/11/2025-11-05-ImageExtension.ss"
                          );
                          
AdExtensionItemDataAccount =  
            SELECT DISTINCT  
                   AccountId,
                   AssetId
        FROM AdExtensionData 
        INNER JOIN FullExtensionItemAssets 
        ON FullExtensionItemAssets.AdExtensionId == AdExtensionData.AdExtensionId; 

ImageExtensionData =
    SELECT AccountId,
           AssetId,
           "ImageExtension" AS AdType
    FROM AdExtensionItemDataAccount;

AccountAssets_ImageExtension =
    SELECT AccountId,
           Convert.ToString(AssetId) AS AssetId,
           AdType,
           AssetType
    FROM AccountAssets
    UNION
    SELECT AccountId,
           AssetId,
           AdType,
           "" AS AssetType
    FROM ImageExtensionData;


AccountsAssetId_ServableAds =
    SELECT DISTINCT A.*
    FROM ValidAccounts AS A
    INNER JOIN 
        AccountServable AS B
        ON A.AccountId == B.AccountId;

Stat =
    SELECT *
    FROM Stat
    UNION ALL
    SELECT "#1 after ServableAds condition" AS key,
           Segment,
           COUNT(DISTINCT AccountId) AS SampleAccountIdCount,
           SUM(RevenueUSD) AS TotalRevenue
    FROM AccountsAssetId_ServableAds
    ;

AccountsAssetId_ServableAds_RankedSamples_Assets =
    SELECT A.*,
           B.AssetId, 
           B.AdType, 
           B.AssetType,
           A.AdTypeMV + "-" + B.AdType AS Displayed_source_AdType
    FROM AccountsAssetId_ServableAds AS A
    INNER JOIN
        AccountAssets_ImageExtension AS B
        ON A.AccountId == B.AccountId;

Stat =     
    SELECT *
    FROM Stat
    UNION ALL
    SELECT "#2 after Join AccountAssets_ImageExtension:<account, Asset> pair" AS key,
           Segment,
           COUNT(DISTINCT AccountId) AS SampleAccountIdCount,
           SUM(RevenueUSD) AS TotalRevenue
    FROM AccountsAssetId_ServableAds_RankedSamples_Assets
    ;

AssetImages =
    SELECT AssetId,
           Url, 
           Size[1] AS Width,
           Size[0] AS Height,
           1.0 * Size[1] / Size[0] AS AspectRatio
    FROM
    (
        SELECT  
               AssetId.ToString() AS AssetId,
               Url,
               ImageUtils.GetSize(Base64Data) AS Size
        FROM AssetImages WHERE Base64Data != null AND Base64Data != ""
    )
    HAVING Width != null AND Height != null AND Width > 0 AND Height > 0;  


AccountsImages =
    SELECT DISTINCT A.*,
           Url AS ImageUrl,
           Width,
           Height,
           AspectRatio
    FROM AccountsAssetId_ServableAds_RankedSamples_Assets AS A
    INNER JOIN
        AssetImages AS B
        ON A.AssetId == B.AssetId;

AccountsImages =
    SELECT *,
           IF(AspectRatio >= 1.77, "WideImages", "TallImages") AS RatioType
    FROM AccountsImages;

OUTPUT TO SSTREAM @AllAccountsFile
    CLUSTERED BY AccountId
          WITH STREAMEXPIRY @StreamExpiry; 

Stat = SELECT *
    FROM Stat
    UNION ALL
    SELECT "#3 after Join Images" AS key,
           Segment,
           COUNT(DISTINCT AccountId) AS SampleAccountIdCount,
           SUM(RevenueUSD) AS TotalRevenue
    FROM AccountsImages;

AccountNoImage =
    SELECT DISTINCT AccountId, Segment,Vertical_L1, RevenueUSD
    FROM AccountsAssetId_ServableAds AS A
    LEFT ANTISEMIJOIN
        AccountsImages AS B
        ON A.AccountId == B.AccountId;

Stat = 
    SELECT *    
    FROM Stat
    UNION ALL
    SELECT "#3.1 SampledNoAccounts" AS key,
           Segment,
           COUNT(DISTINCT AccountId) AS SampleAccountIdCount,
           SUM(RevenueUSD) AS TotalRevenue
    FROM AccountNoImage
    ;

SampledAccountsImages = 
    SELECT DISTINCT Segment, AccountId
    FROM AccountsImages;  

SampledAccountsImages = 
SELECT *,
    ROW_NUMBER() OVER (
                PARTITION BY Segment
                ORDER BY RandomGenerator.GetRandom() DESC
            ) AS RandRank
    FROM SampledAccountsImages;

SampledAccountsImages = 
    SELECT Segment, AccountId
    FROM SampledAccountsImages
    WHERE RandRank <= 500;

SampleImages = SELECT A.*
    FROM AccountsImages AS A
    INNER JOIN SampledAccountsImages AS B
        ON A.Segment == B.Segment AND A.AccountId == B.AccountId;

OUTPUT SampleImages TO SSTREAM @SampledAccountsFile
    CLUSTERED BY Segment,Vertical_L1
    WITH STREAMEXPIRY @StreamExpiry;


ImageSizeStat = 
    SELECT "AllAccountsImages" AS Source,
            Segment,
           COUNT(DISTINCT AccountId) AS AccountCount,
           COUNTIF(RatioType == "TallImages") AS TallImagesCount,
           COUNTIF(RatioType == "WideImages") AS WideImagesCount
    FROM AccountsImages
    UNION ALL
    SELECT  "SampledAccountsImages" AS Source,
            Segment,
           //Vertical_L1,
           COUNT(DISTINCT AccountId) AS AccountCount,
           COUNTIF(RatioType == "TallImages") AS TallImagesCount,
           COUNTIF(RatioType == "WideImages") AS WideImagesCount
    FROM SampleImages;
OUTPUT TO SSTREAM @RatioDistributionFile
    CLUSTERED BY Segment
          WITH STREAMEXPIRY @StreamExpiry;

Stat = SELECT *
    FROM Stat
    UNION ALL
    SELECT "#4 after SampledAccountsImages" AS key,
           Segment,
           COUNT(DISTINCT AccountId) AS SampleAccountIdCount,
           SUM(RevenueUSD) AS TotalRevenue
    FROM SampleImages
    ;
AggregatedAccountImages =
    REDUCE SampleImages
    ON AccountId
    USING AggregateImageByAspectReducer;

OUTPUT AggregatedAccountImages TO SSTREAM @AggregatedAccountImagesFile
    CLUSTERED BY Segment,Vertical_L1
    WITH STREAMEXPIRY @StreamExpiry;

Stat = SELECT *    
    FROM Stat
    UNION ALL
    SELECT "#5 after AggregatedAccountImages" AS key,
           Segment,
           COUNT(DISTINCT AccountId) AS SampleAccountIdCount,
           SUM(RevenueUSD) AS TotalRevenue
    FROM AggregatedAccountImages
    ;
OUTPUT TO SSTREAM @StatFile
    CLUSTERED BY key, Segment
          WITH STREAMEXPIRY @StreamExpiry;




