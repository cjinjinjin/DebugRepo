// Input Params
#DECLARE RunDate DateTime = DateTime.Parse("2025-11-02");
#DECLARE OutputFolder string = "//local/user/jinjinchen/AdDemandMeasurement/FullExtension/";
#DECLARE StreamExpiry string = "60";

// Modules and Views
MODULE "/shares/bingads.algo.prod.adinsights/data/AdInsightMeasurement/Common/modules/RecommendationMeasurement.module" AS RecMod;
MODULE "/shares/bingads.algo.prod.adinsights/data/shared_data/AdvertiserEngagement/Metallica/prod/CommonDataFeed/Modules/C2C.module" AS C2C;
#DECLARE UnifiedLayerPerf string = "/shares/bingAds.BI.OI/AdsOI/DemandMetrics/Views/UnifiedLayerPerf.view";

// Libraries
//REFERENCE "/shares/bingads.algo.prod.adinsights/data/AdInsightMeasurement/Common/dlls/OpportunityTypeLib.dll";
