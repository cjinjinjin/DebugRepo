#CS

using System;
using System.Collections.Generic;
using System.Linq;
using ScopeRuntime;
using System.IO;
using System.Text;
using Microsoft.SCOPE.Types;
using System.Web;
using System.Text.RegularExpressions;
using System.IO.Compression;
using System.Drawing.Imaging;
using System.Drawing;

public static class ImageUtils
{
    public static int[] GetSize(string base64string)
    {
        if (string.IsNullOrWhiteSpace(base64string))
            return new int[] { 0, 0 };

        try
        {
            // ????? "data:image/png;base64," ??
            var commaIndex = base64string.IndexOf(',');
            if (commaIndex > 0)
                base64string = base64string.Substring(commaIndex + 1);

        var bytes = Convert.FromBase64String(base64string);
            if (bytes.Length == 0)
                return new int[] { 0, 0 };

        using (var stream = new MemoryStream(bytes))
            using (var image = Image.FromStream(stream, useEmbeddedColorManagement: false, validateImageData: false))
            {
                return new int[] { image.Height, image.Width };
            }
        }
        catch (FormatException)
        {
            // Base64 ????
            return new int[] { 0, 0 };
        }
        catch (ArgumentException)
        {
            // ????????????
            return new int[] { 0, 0 };
        }
        catch (Exception)
        {
            // ??????
            return new int[] { 0, 0 };
        }
    }
} 

public class AggregateKeywordsByAdIdReducer : Reducer
{
    // 定义 Reducer 的输出 Schema
    public override Schema Produces(string[] requestedColumns, string[] args, Schema input)
    {
        var schema = new Schema();
        
        // 1. 保留除了 ListingId 和 Keyword 之外的所有列（K AdId 也会被保留）
        // 假设输入包含: <AdId, ListingId, Keyword, ...>
        foreach (var col in input.Columns)
        {
            if (col.Name != "ListingId" && col.Name != "Keyword")
            {
                schema.Add(col);
            }
        }
        
        // 2. 添加聚合后的新列
        // 存储 ListingId 对应的去重后的 Keyword 集合，以 "##!" 分隔
        schema.Add(new ColumnInfo("AggregatedKeywords", typeof(string)));
        
        return schema;
    }
   
    // Reducer 的核心逻辑
    public override IEnumerable<Row> Reduce(RowSet input, Row outputRow, string[] args)
    {
        outputRow.Reset();
        
        var listingKeywords = new List<string>(); 
        bool firstRead = true;
        
        // 确定需要复制的公共列（AdId 和其他非聚合列）的范围。
        // 由于我们在 Produces 中移除了 ListingId 和 Keyword，
        // 只需要复制到第一个聚合列 "AggregatedKeywords" 之前的所有列。
        int commonColumnsEnd = outputRow.Schema.IndexOf("AggregatedKeywords");
        
        foreach (Row row in input.Rows)
        {
            // --- 复制公共列逻辑 ---
            if (firstRead)
            {
                // 仅复制 AdId 和其他公共列（如 CampaignId 等）一次
                for (int i = 0; i < commonColumnsEnd; i++)
                {
                    string colName = outputRow.Schema[i].Name;
                    // 确保原始行包含这个列
                    if (row.Schema.Contains(colName))
                    {
                        row[colName].CopyTo(outputRow[i]);
                    }
                }
                firstRead = false;
            }
            
            // --- 聚合逻辑 ---
            
            // 获取当前行的 ListingId 和 Keyword
            string listingId = row["ListingId"].String;
            string keyword = row["Keyword"].String;
           
            if (!string.IsNullOrEmpty(listingId) && !string.IsNullOrEmpty(keyword))
            {
                listingKeywords.Add(keyword);
            }
        }
        
        // --- 最终处理和输出 ---

        // 使用 "##!" 分隔符连接所有去重后的 Keyword
        string aggregatedKeywords = string.Join("##!", listingKeywords);
        
        // 设置新的聚合列的值
        outputRow["AggregatedKeywords"].Set(aggregatedKeywords);
        
        // 产出聚合后的行
        yield return outputRow;
    }
}

#ENDCS