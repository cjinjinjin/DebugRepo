#DECLARE OutputFileImage string = string.Format("{0}/AdLevel_TA_Image_{1:yyyy-MM-dd}.ss", @OutputFolder, @RunDate);
#DECLARE OutputFile_Pmax string = string.Format("{0}/AdLevel_PMAX_{1:yyyy-MM-dd}.ss", @OutputFolder, @RunDate);
#DECLARE OutputFile_PmaxImage string = string.Format("{0}/AdLevel_PMAXImage_{1:yyyy-MM-dd}.ss", @OutputFolder, @RunDate);
#DECLARE CampaignWithoutImage string = string.Format("{0}/CampaignWithoutImage_{1:yyyy-MM-dd}.ss", @OutputFolder, @RunDate);
#DECLARE ExcludeExtesnionOutputFile string = string.Format("{0}/ExcludeExtesnionOutputFile_{1:yyyy-MM-dd}.ss", @OutputFolder, @RunDate);
#DECLARE KeywordOutputFile string = string.Format("{0}/AdLevel_Keyword_{1:yyyy-MM-dd}.ss", @OutputFolder, @RunDate);
#DECLARE StatFile string = string.Format("{0}/AdLevel_Overall_{1:yyyy-MM-dd}.stat", @OutputFolder, @RunDate);
AssetImages =
    SSTREAM SPARSE STREAMSET "/shares/bingAds.BI.OI/AdsOI/ObjectStoreDump/Images"
                   PATTERN @"Assets_"+@CurrentDataStrforImage + @"_%n.ss"
                   RANGE __serialnum = ["1", "5"];
#DECLARE C2CMasterViewPath string = "/shares/adCenter.BICore.upload/prod/C2C/Views/MasterView/C2CMasterView.view"; 
#DECLARE UACView string = @"/shares/bingads.platform.prod.indexgen/Data/publish/UAC/UAC.view"; 
#DECLARE MonetizationView string = @"/shares/adCenter.BICore.SubjectArea/SubjectArea/Monetization/views/PROD/MonetizationFacts.view";
#DECLARE UnifiedLayerDemandView string = "/shares/bingAds.BI.OI/AdsOI/DemandMetrics/Views/UnifiedLayerDemand.view"; 
#DECLARE LimitedDays int = int.Parse("1");
REFERENCE @"System.IO.Compression.dll";
REFERENCE @"System.IO.Compression.FileSystem.dll";
REFERENCE @"System.Drawing.dll";

NativeEligibleCampaigns =
    SELECT *.Except(AccountId, CampaignId),
           AccountId.ToString() AS AccountId,
           CampaignId.ToString() AS CampaignId
    FROM
    (
        SSTREAM @NativeEligibleCampaigns
    );


// ImageExtension
AdExtension =
    SELECT AdExtensionTypeId,
           AdExtensionId
    FROM
    (
        VIEW @C2CMasterViewPath
        PARAMS
        (
            ViewName = "AdExtension_Raw",
            DataMode = "PROD",
            ViewMode = "PROD",
            ViewType = 1,
            RequestEndDateUtc = @RunDate,
            RequestEndHourUtc = 23
        )
    )
    WHERE LifeCycleStatusId != 110 AND AdExtensionTypeId == 35; // for ImageExtension only

AdExtensionAccountView =  
            SELECT AccountId.ToString() AS AccountId,  
                   AdExtensionId  
            FROM  
            (  
                VIEW @C2CMasterViewPath  
                PARAMS  
                (  
                      ViewName = "AdExtensionAccount_Raw",  
                      ViewType=1,                
                      RequestEndDateUtc= @RunDate,  
                    RequestEndHourUtc = 23          
                )  
            )
    WHERE LifeCycleStatusId != 110;
AdExtensionAccountView =
    SELECT A.*
    FROM AdExtensionAccountView AS A
    INNER JOIN
        AdExtension AS B
        ON A.AdExtensionId == B.AdExtensionId; // filter only ImageExtension Account

AdExtensionCampaignView =  
            SELECT AccountID.ToString() AS AccountId, CampaignId.ToString() AS CampaignId, 
                   AdExtensionId  
            FROM  
            (  
    VIEW @C2CMasterViewPath  
            PARAMS   
            (  
                      ViewName = "AdExtensionCampaign_Raw",  
                      ViewType=1,                
                      RequestEndDateUtc= @RunDate,  
                RequestEndHourUtc = 23 
                )  
            )
    WHERE LifeCycleStatusId != 110;
AdExtensionCampaignView =
    SELECT A.*
    FROM AdExtensionCampaignView AS A
    INNER JOIN
        AdExtension AS B
        ON A.AdExtensionId == B.AdExtensionId; // filter only ImageExtension Campaign

AdExtensionOrderView =  
            SELECT AccountID.ToString() AS AccountId, CampaignId.ToString() AS CampaignId,  
                   AdExtensionId  
            FROM  
            (  
                VIEW @C2CMasterViewPath  
                PARAMS  
                (  
                      ViewName = "AdExtensionOrder_Raw",  
                      ViewType=1,                
                      RequestEndDateUtc= @RunDate,  
                    RequestEndHourUtc = 23  
                )  
            )
    WHERE LifeCycleStatusId != 110; 
AdExtensionOrderView =
    SELECT A.*
    FROM AdExtensionOrderView AS A
    INNER JOIN
        AdExtension AS B
        ON A.AdExtensionId == B.AdExtensionId; // filter only ImageExtension Order

//end: ImageAssets

Input_excludeImageExtension =
    SELECT A.*
    FROM NativeEligibleCampaigns AS A
    LEFT ANTISEMIJOIN
        AdExtensionAccountView AS B
        ON A.AccountId == B.AccountId
    LEFT ANTISEMIJOIN
        AdExtensionCampaignView AS C
        ON A.AccountId == C.AccountId AND A.CampaignId == C.CampaignId
    LEFT ANTISEMIJOIN
        AdExtensionOrderView AS D
        ON A.AccountId == D.AccountId AND A.CampaignId == D.CampaignId;

//OUTPUT TO SSTREAM @ExcludeExtesnionOutputFile;

Stat = SELECT "#1 Input Campaign" AS K,
           COUNT(DISTINCT CampaignId) AS V
    FROM NativeEligibleCampaigns
    UNION ALL
    SELECT "#2 Exclude Image Extension Campaign" AS K,
           COUNT(DISTINCT CampaignId) AS V
    FROM Input_excludeImageExtension;

MZ=
    SELECT DISTINCT
           AdvertiserAccountId.ToString() AS AccountId,
           CampaignId.ToString() AS CampaignId,
           AdId.ToString() AS AdId,
           AdDisplayTypeId,
           DomainType,
           //(AdDisplayTypeId == 1 && DomainType == 1? "TextAd" : DomainType == 5? "DSA" : AdDisplayTypeId == 1024? "ExTA" : AdDisplayTypeId == 256? "AppInstall" : AdDisplayTypeId == 5? "ProductListingAd" : AdDisplayTypeId == 8192? "RSA" : "Unknown") AS AdTypeMV,
           CampaignTypeId
    FROM
    (
        VIEW @MonetizationView
        PARAMS
        (
            StartDateTimeUtc = @RunDate.AddDays(-@LimitedDays),
            EndDateTimeUtc = @RunDate,
            BillableStatus = "NonFraud" //NonFraud: FraudQualityBand > 1, to improve latency
        )
     )
    WHERE FraudQualityBand > 1;
    ;
    
AggregateKeywords =
    SELECT DISTINCT B.*
    FROM Input_excludeImageExtension AS A
    INNER JOIN
        MZ AS B
        ON A.CampaignId == B.CampaignId AND A.AccountId == B.AccountId; // keyword aggrate to AdId level: ~6 images, campaign budget view monthly(youlin)

