REFERENCE "/shares/WebDataPlatform/local/Griffin/DLLs/Microsoft.Bing.HashUtil.dll";
USING Microsoft.Bing.HashUtil;

#DECLARE RunDate DateTime = DateTime.Parse("2025-11-19");
#DECLARE RunDateStr string = @RunDate.ToString("yyyy-MM-dd");
